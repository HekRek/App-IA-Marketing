{
  "entities": {
    "OwnerProfile": {
      "title": "Owner Profile",
      "description": "Business profile of the owner",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "personalUrl": { "type": "string" },
        "companyUrl": { "type": "string" },
        "sector": { "type": "string" },
        "location": { "type": "string" }
      }
    },
    "Competitor": {
      "title": "Competitor",
      "description": "Analysis of a competitor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "website": { "type": "string" },
        "sector": { "type": "string" },
        "location": { "type": "string" },
        "strengths": { "type": "array", "items": { "type": "string" } },
        "weaknesses": { "type": "array", "items": { "type": "string" } },
        "valueProposition": { "type": "string" }
      }
    },
    "ICP": {
      "title": "Ideal Customer Profile",
      "description": "Detailed ICP definition",
      "type": "object",
      "properties": {
        "sector": { "type": "string" },
        "companySize": { "type": "string" },
        "location": { "type": "string" },
        "problemSolved": { "type": "string" },
        "budgetRange": { "type": "string" },
        "preferredChannel": { "type": "string" },
        "urgency": { "type": "string", "enum": ["Alta", "Media", "Baja"] },
        "marketingIdeas": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Lead": {
      "title": "Lead",
      "description": "A potential customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyName": { "type": "string" },
        "sector": { "type": "string" },
        "city": { "type": "string" },
        "country": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "website": { "type": "string" },
        "source": { "type": "string" },
        "estimatedRevenue": { "type": "string" },
        "addedAt": { "type": "string" },
        "notes": { "type": "string" },
        "score": { "type": "number" }
      }
    },
    "SocialPost": {
      "title": "Social Post",
      "description": "A scheduled social media post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "content": { "type": "string" },
        "platform": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "MarketingCampaign": {
      "title": "Marketing Campaign",
      "description": "Generated marketing assets",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "imageUrl": { "type": "string" }
      }
    },
    "ROIReport": {
      "title": "ROI Report",
      "description": "Calculated ROI metrics",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "investment": { "type": "number" },
        "leadsGenerated": { "type": "number" },
        "salesMade": { "type": "number" },
        "revenue": { "type": "number" },
        "roiPercentage": { "type": "number" }
      }
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "Track of actions performed",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string" },
        "action": { "type": "string" },
        "module": { "type": "string" },
        "details": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}/owner/data": { "schema": "OwnerProfile", "description": "User profile" },
    "/users/{userId}/leads/{leadId}": { "schema": "Lead", "description": "User leads" },
    "/users/{userId}/competitors/{competitorId}": { "schema": "Competitor", "description": "Competitor analysis" },
    "/users/{userId}/icp/data": { "schema": "ICP", "description": "ICP profile" },
    "/users/{userId}/posts/{postId}": { "schema": "SocialPost", "description": "Social media posts" },
    "/users/{userId}/roi/{roiId}": { "schema": "ROIReport", "description": "ROI calculations" },
    "/users/{userId}/logs/{logId}": { "schema": "ActivityLog", "description": "Activity logs" },
    "/users/{userId}/marketing_content/{campaignId}": { "schema": "MarketingCampaign", "description": "Marketing generated content" }
  }
}
