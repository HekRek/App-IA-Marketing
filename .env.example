# Gemini API Key (required)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps API Key (optional - for location autocomplete in Lead Search)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# HMR configuration (optional - set to true to disable Hot Module Replacement)
# DISABLE_HMR=false
